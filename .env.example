# Market Signal Engine — Environment Configuration
# Copy to .env and edit secrets before deploying

# App
APP_NAME=Market Signal Engine
DEBUG=false
READ_ONLY_SIGNAL_ONLY=true

# Database (matches docker-compose postgres credentials)
DATABASE_URL=postgresql://market:market_dev@postgres:5432/market_signals
DB_PASSWORD=market_dev

# Chatbot RAG — Anthropic API key required for the Spanish chatbot
ANTHROPIC_API_KEY=sk-ant-your_key_here

# API Keys (replace with your own)
YFINANCE_ENABLED=true
FINNHUB_KEY=your_finnhub_key_here
BINANCE_ENABLED=true
BLOCKCHAIN_ENABLED=true
WHALE_ALERT_KEY=
DEXSCREENER_ENABLED=true
DEFILLAMA_ENABLED=true

# Telegram Bot (replace with your bot token and chat ID)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ALERTS_ENABLED=false

# Scheduling intervals (seconds)
COLLECTOR_INTERVAL=300
ANALYSIS_INTERVAL=600
SIGNAL_CHECK_INTERVAL=60
